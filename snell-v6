#!/usr/bin/env bash
set -Eeuo pipefail

SNELL_VERSION="${SNELL_VERSION:-6.0.0b2}"
SNELL_PORT="${SNELL_PORT:-}"
SNELL_PSK="${SNELL_PSK:-}"
ENABLE_IPV6="${ENABLE_IPV6:-0}"
DNS_IP_PREFERENCE="${DNS_IP_PREFERENCE:-default}"

SERVICE_NAME="snell-v6"
SERVICE_USER="nobody"
SERVICE_GROUP="nogroup"

CONFIG_DIR="/etc/snell-v6"
CONFIG_FILE="${CONFIG_DIR}/snell-server.conf"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
BIN_FILE="/usr/local/bin/snell-server-v6"
CLIENT_FILE="/root/snell-v6-client.conf"

OLD_SELF_SERVICE_FILE="/etc/systemd/system/snell.service"

log() {
  echo "[snell-v6] $*"
}

die() {
  echo "[snell-v6] ERROR: $*" >&2
  exit 1
}

need_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    die "Please run as root, for example: sudo bash snell-v6"
  fi
}

need_systemd() {
  command -v systemctl >/dev/null 2>&1 || die "systemctl was not found. This script requires systemd."
}

detect_arch() {
  local machine
  machine="$(uname -m)"

  case "${machine}" in
    x86_64 | amd64)
      echo "amd64"
      ;;
    aarch64 | arm64)
      echo "aarch64"
      ;;
    armv7l | armv7)
      echo "armv7l"
      ;;
    i386 | i686)
      echo "i386"
      ;;
    *)
      die "Unsupported architecture: ${machine}"
      ;;
  esac
}

random_port() {
  local port

  while true; do
    port="$(shuf -i 20000-60999 -n 1)"
    if ! ss -lntH 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]${port}$"; then
      echo "${port}"
      return
    fi
  done
}

random_psk() {
  openssl rand -hex 32
}

install_deps() {
  log "Installing dependencies..."

  if command -v apt-get >/dev/null 2>&1; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y ca-certificates wget unzip curl openssl iproute2 coreutils
    return
  fi

  if command -v dnf >/dev/null 2>&1; then
    dnf install -y ca-certificates wget unzip curl openssl iproute coreutils
    return
  fi

  if command -v yum >/dev/null 2>&1; then
    yum install -y ca-certificates wget unzip curl openssl iproute coreutils
    return
  fi

  die "Unsupported package manager. Please install wget, unzip, curl, openssl, iproute/iproute2 and coreutils manually."
}

ensure_service_identity() {
  if ! id -u "${SERVICE_USER}" >/dev/null 2>&1; then
    SERVICE_USER="root"
    SERVICE_GROUP="root"
    return
  fi

  if ! getent group "${SERVICE_GROUP}" >/dev/null 2>&1; then
    SERVICE_GROUP="$(id -gn "${SERVICE_USER}")"
  fi
}

cleanup_old_self_service() {
  if [[ -f "${OLD_SELF_SERVICE_FILE}" ]] &&
    grep -q "/usr/local/bin/snell-server -c /etc/snell/snell-server.conf" "${OLD_SELF_SERVICE_FILE}"; then
    log "Removing old snell.service created by the previous script..."
    systemctl disable --now snell >/dev/null 2>&1 || true
    rm -f "${OLD_SELF_SERVICE_FILE}"
    systemctl daemon-reload || true
  fi
}

install_snell() {
  local arch url tmp_dir zip_file
  arch="$(detect_arch)"
  url="https://dl.nssurge.com/snell/snell-server-v${SNELL_VERSION}-linux-${arch}.zip"
  tmp_dir="$(mktemp -d)"
  zip_file="${tmp_dir}/snell-server.zip"

  log "Downloading Snell Server v${SNELL_VERSION} for linux-${arch}..."
  wget -qO "${zip_file}" "${url}" || die "Download failed: ${url}"
  unzip -oq "${zip_file}" -d "${tmp_dir}"

  if [[ ! -f "${tmp_dir}/snell-server" ]]; then
    rm -rf "${tmp_dir}"
    die "snell-server binary was not found in the downloaded archive"
  fi

  install -m 755 "${tmp_dir}/snell-server" "${BIN_FILE}"
  rm -rf "${tmp_dir}"
}

write_config() {
  local listen_value tmp_file

  if [[ -z "${SNELL_PORT}" ]]; then
    SNELL_PORT="$(random_port)"
  fi

  if [[ -z "${SNELL_PSK}" ]]; then
    SNELL_PSK="$(random_psk)"
  fi

  if [[ "${ENABLE_IPV6}" == "1" || "${ENABLE_IPV6}" == "true" ]]; then
    listen_value="0.0.0.0:${SNELL_PORT},[::]:${SNELL_PORT}"
  else
    listen_value="0.0.0.0:${SNELL_PORT}"
  fi

  install -d -m 750 -o root -g "${SERVICE_GROUP}" "${CONFIG_DIR}"
  tmp_file="$(mktemp)"
  cat >"${tmp_file}" <<EOF
[snell-server]
listen = ${listen_value}
psk = ${SNELL_PSK}
dns-ip-preference = ${DNS_IP_PREFERENCE}
EOF

  install -m 640 -o root -g "${SERVICE_GROUP}" "${tmp_file}" "${CONFIG_FILE}"
  rm -f "${tmp_file}"
}

write_service() {
  cat >"${SERVICE_FILE}" <<EOF
[Unit]
Description=Snell v6 Proxy Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=${SERVICE_USER}
Group=${SERVICE_GROUP}
LimitNOFILE=32768
ExecStart=${BIN_FILE} -c ${CONFIG_FILE}
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
EOF
}

open_firewall_if_needed() {
  if command -v ufw >/dev/null 2>&1 && ufw status | grep -qi "Status: active"; then
    log "Opening TCP ${SNELL_PORT} in UFW..."
    ufw allow "${SNELL_PORT}/tcp"
  fi

  if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state >/dev/null 2>&1; then
    log "Opening TCP ${SNELL_PORT} in firewalld..."
    firewall-cmd --permanent --add-port="${SNELL_PORT}/tcp" >/dev/null
    firewall-cmd --reload >/dev/null
  fi
}

format_host_for_surge() {
  local host="$1"

  if [[ "${host}" == *:* && "${host}" != \[* ]]; then
    echo "[${host}]"
  else
    echo "${host}"
  fi
}

public_ip() {
  local ip
  ip="$(curl -4fsS --max-time 6 https://api.ipify.org 2>/dev/null || true)"

  if [[ -z "${ip}" ]]; then
    ip="$(curl -4fsS --max-time 6 https://ifconfig.me 2>/dev/null || true)"
  fi

  if [[ -z "${ip}" && ( "${ENABLE_IPV6}" == "1" || "${ENABLE_IPV6}" == "true" ) ]]; then
    ip="$(curl -6fsS --max-time 6 https://api64.ipify.org 2>/dev/null || true)"
  fi

  if [[ -z "${ip}" ]]; then
    ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
  fi

  format_host_for_surge "${ip:-YOUR_SERVER_IP}"
}

write_client_config() {
  local server_ip tmp_file
  server_ip="$(public_ip)"
  tmp_file="$(mktemp)"

  cat >"${tmp_file}" <<EOF
# Surge client configuration
# Add this line under the [Proxy] section:

Snell-v6 = snell, ${server_ip}, ${SNELL_PORT}, psk=${SNELL_PSK}, version=6
EOF

  install -m 600 -o root -g root "${tmp_file}" "${CLIENT_FILE}"
  rm -f "${tmp_file}"
}

start_service() {
  systemctl daemon-reload || return 1
  systemctl enable "${SERVICE_NAME}" >/dev/null || return 1
  systemctl restart "${SERVICE_NAME}" || return 1
  sleep 1
  systemctl is-active --quiet "${SERVICE_NAME}"
}

print_result() {
  local status="$1"

  echo
  echo "========== Snell v6 =========="
  echo "Status: ${status}"
  echo
  echo "Server config:"
  echo "  ${CONFIG_FILE}"
  echo
  echo "Surge client config:"
  sed 's/^/  /' "${CLIENT_FILE}"
  echo
  echo "Useful commands:"
  echo "  systemctl status ${SERVICE_NAME} --no-pager"
  echo "  journalctl -u ${SERVICE_NAME} -n 80 --no-pager"
  echo "  cat ${CLIENT_FILE}"
  echo
  echo "If your VPS provider has a cloud firewall/security group, allow TCP ${SNELL_PORT} there too."
}

print_failure_details() {
  echo
  echo "Service failed to start. Recent logs:"
  journalctl -u "${SERVICE_NAME}" -n 80 --no-pager || true
}

main() {
  need_root
  need_systemd
  install_deps
  ensure_service_identity
  cleanup_old_self_service
  install_snell
  write_config
  write_service
  write_client_config
  open_firewall_if_needed

  if start_service; then
    print_result "running"
  else
    print_result "failed"
    print_failure_details
    exit 1
  fi
}

main "$@"
